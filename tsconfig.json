{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",

    

    "moduleResolution": "bundler",
    

    "ignoreDeprecations": "6.0", 

    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "allowJs": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["src"]
}